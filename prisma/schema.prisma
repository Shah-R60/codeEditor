generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  RECRUITER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questionsCreated Question[]
  sessions         Session[]
  hiringDrives     HiringDrive[]
}

// 1. The Coding Problems
model Question {
  id          String     @id @default(uuid())
  title       String
  description String
  difficulty  String     // "EASY", "MEDIUM", "HARD"
  boilerplate Json?      

  creatorId   String?
  creator     User?      @relation(fields: [creatorId], references: [id])

  testCases   TestCase[]
  sessions    Session[]
}

// 2. The Test Cases for the Judge
model TestCase {
  id             String   @id @default(uuid())
  questionId     String
  input          String
  expectedOutput String
  isHidden       Boolean  @default(false)
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 3. The Interview / OA Rooms
model Session {
  id         String   @id @default(uuid())
  type       String   // "OA" or "INTERVIEW"
  questionId String
  status     String   @default("PENDING") // PENDING, ONGOING, COMPLETED
  createdAt  DateTime @default(now())

  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  question   Question @relation(fields: [questionId], references: [id])
}

// 4. Hiring Drives (formerly Jobs)
model HiringDrive {
  id          String   @id @default(uuid())
  title       String
  department  String?
  location    String?  @default("Online")
  announcements Json?
  status      String   @default("Active") // Active, Draft, Closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recruiterId String
  recruiter   User     @relation(fields: [recruiterId], references: [id])

  rounds      Round[]
  candidates  Candidate[]
}

// 5. Hiring Pipeline Rounds (formerly Stages)
model Round {
  id          String   @id @default(uuid())
  hiringDriveId String
  name        String
  type        String   // "Online Assessment", "Technical Interview", etc.
  duration    String?
  description String?
  order       Int      @default(0)
  
  // Scheduling
  startDate   DateTime?
  endDate     DateTime?
  timeZone    String?
  deadline    DateTime?
  
  // Advanced Configuration
  config      Json?

  hiringDrive HiringDrive @relation(fields: [hiringDriveId], references: [id], onDelete: Cascade)
}

// 6. Candidates
model Candidate {
  id            String   @id @default(uuid())
  hiringDriveId String
  name          String
  email         String
  stage         String   @default("Applied")
  status        String   @default("In Review") // In Review, Passed, Rejected
  score         String?
  rank          Int?
  timeTaken     String?
  submissions   Json?
  stageData     Json?    @default("{}")
  resumeFile    String?
  resumeData    Json?
  createdAt     DateTime @default(now())

  hiringDrive   HiringDrive @relation(fields: [hiringDriveId], references: [id], onDelete: Cascade)
}

// 7. Demo Questions for Practice Sandbox
model DemoQuestion {
  id          String         @id @default(uuid())
  title       String
  description String
  difficulty  String         // "EASY", "MEDIUM", "HARD"
  boilerplate Json?      
  testCases   DemoTestCase[]
}

model DemoTestCase {
  id               String       @id @default(uuid())
  demoQuestionId   String
  input            String
  expectedOutput   String
  isHidden         Boolean      @default(false)
  demoQuestion     DemoQuestion @relation(fields: [demoQuestionId], references: [id], onDelete: Cascade)
}