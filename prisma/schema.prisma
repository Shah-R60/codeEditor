generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  RECRUITER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questionsCreated Question[]
  sessions         Session[]
  jobs             Job[]
}

// 1. The Coding Problems
model Question {
  id          String     @id @default(uuid())
  title       String
  description String
  difficulty  String     // "EASY", "MEDIUM", "HARD"
  boilerplate Json?      

  creatorId   String?
  creator     User?      @relation(fields: [creatorId], references: [id])

  testCases   TestCase[]
  sessions    Session[]
}

// 2. The Test Cases for the Judge
model TestCase {
  id             String   @id @default(uuid())
  questionId     String
  input          String
  expectedOutput String
  isHidden       Boolean  @default(false)
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 3. The Interview / OA Rooms
model Session {
  id         String   @id @default(uuid())
  type       String   // "OA" or "INTERVIEW"
  questionId String
  status     String   @default("PENDING") // PENDING, ONGOING, COMPLETED
  createdAt  DateTime @default(now())

  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  question   Question @relation(fields: [questionId], references: [id])
}

// 4. Hiring Plans (Jobs)
model Job {
  id          String   @id @default(uuid())
  title       String
  department  String?
  status      String   @default("Active") // Active, Draft, Closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recruiterId String
  recruiter   User     @relation(fields: [recruiterId], references: [id])

  stages      Stage[]
  candidates  Candidate[]
}

// 5. Hiring Pipeline Stages
model Stage {
  id          String   @id @default(uuid())
  jobId       String
  name        String
  type        String   // "Automated" or "Live Coding"
  duration    String
  description String?
  order       Int      @default(0)

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// 6. Candidates
model Candidate {
  id          String   @id @default(uuid())
  jobId       String
  name        String
  email       String
  stage       String   @default("Applied")
  status      String   @default("In Review") // In Review, Passed, Rejected
  score       String?
  timeTaken   String?
  createdAt   DateTime @default(now())

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}